# Environment Configuration
NODE_ENV=development

# Application Configuration
APP_NAME="Tierlist Builder"
APP_VERSION="1.0.0"
APP_URL=http://localhost:3000

# Database Configuration (PostgreSQL-compatible - Supabase, Neon, Railway, etc.)
# Get these from your database provider dashboard
DATABASE_URL=https://your-project-id.supabase.co
DATABASE_ANON_KEY=your-database-anon-key

# Object Storage Configuration (S3-compatible - Vultr, AWS S3, DigitalOcean Spaces, etc.)
# Get these from your object storage provider dashboard
S3_ENDPOINT=https://ewr1.vultrobjects.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=tierlist-images
S3_REGION=us-east-1
S3_PORT=9000
S3_CONSOLE_PORT=9001

# File Upload Limits
MAX_IMAGE_SIZE=5242880
MAX_TIER_ITEMS=50
MAX_TIERS=10

# Supported Image Types (comma-separated)
SUPPORTED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Auto-save Configuration
AUTO_SAVE_INTERVAL=30000

# API Configuration
API_TIMEOUT=10000

# Development Configuration
DEBUG_MODE=true
ENABLE_DEVTOOLS=true

# Build Configuration
BUILD_SOURCEMAP=true

# Performance Configuration
LAZY_LOADING=true
IMAGE_OPTIMIZATION=true